DATABASE_URL=postgresql://postgres:password@localhost:5432/lobbyscope

# Clau API d'Anthropic (per a la classificació LLM de connexions, sessió 7)
ANTHROPIC_API_KEY=sk-ant-...

# Token opcional de l'API Socrata — millora el rate limit (de ~1000 a ~10000 req/h)
# Registre gratuït a: https://dev.socrata.com/register
SOCRATA_APP_TOKEN=

# Model d'embeddings local (sentence-transformers)
# LaBSE: multilingüe, 768 dims, ~1.8GB — recomanat per a català
# Alternativa lleugera: sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 (384 dims)
# NOTA: es descarrega automàticament en el primer ús des de HuggingFace
EMBEDDING_MODEL=sentence-transformers/LaBSE
EMBEDDING_DIMS=768

# Posar a true quan pgvector estigui instal·lat a PostgreSQL
# Sense pgvector, les columnes d'embedding uses REAL[] (schema_novector.sql)
PGVECTOR_ENABLED=false
